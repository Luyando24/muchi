# Example environment variables file
# Copy this file to .env and fill in your actual values
# DO NOT commit the actual .env file to version control

# Builder.io API Key
# https://www.builder.io/c/docs/using-your-api-key
VITE_PUBLIC_BUILDER_KEY=your_builder_public_key_here
PING_MESSAGE=your_ping_message_here

# Application URL Configuration
# The URL of the frontend application (Vite dev server runs on 8080 by default)
VITE_APP_URL=http://localhost:8080
APP_URL=http://localhost:8080


# Database Configuration
# Database Configuration
# For Vercel/Supabase, use the connection string provided by Supabase
# accessing via calling separate environment variables is supported for local dev
DATABASE_URL=postgres://postgres.your-project:password@aws-0-region.pooler.supabase.com:6543/postgres
# Direct connection for migrations (if needed)
DIRECT_URL=postgres://postgres.your-project:password@aws-0-region.supabase.com:5432/postgres

# Legacy/Local vars (optional if DATABASE_URL is set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=muchi_db
DB_USER=postgres
DB_PASSWORD=password

# NRC Hashing Salt (for student privacy)
NRC_SALT=your_secure_salt_here

# Groq AI API Key Configuration
GROQ_API_KEY=your_groq_api_key_here